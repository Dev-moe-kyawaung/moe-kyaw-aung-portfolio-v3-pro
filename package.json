  "scripts": {
    "dev": "vite",
    "dev:https": "vite --https",
    "build": "vite build",
    "build:prod": "vite build --mode production",
    "build:analyze": "vite build --mode analyze",
    "build:stats": "vite build && npx vite-bundle-visualizer",
    "preview": "vite preview",
    "preview:prod": "vite preview --mode production",
    "lint": "eslint src --ext .jsx,.js,.ts,.tsx",
    "lint:fix": "eslint src --ext .jsx,.js,.ts,.tsx --fix",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx,css,md}",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "chromatic": "chromatic --project-token <token>",
    "prepare": "husky install",
    "release": "semantic-release",
    "vercel:install": "vercel install",
    "vercel:dev": "vercel dev",
    "vercel:build": "vercel build",
    "vercel:deploy": "vercel deploy --prod",
    "cloudflare:dev": "wrangler dev",
    "cloudflare:deploy": "wrangler deploy",
    "lambda:build": "serverless package",
    "lambda:deploy": "serverless deploy"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ],
    "*.{css,md}": [
      "prettier --write",
      "git add"
    ]
  },
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "packages/*"
  ],
  "private": true
